# API密钥配置示例
# 复制此文件为 .env 并填入你的真实密钥

# OpenAI API密钥（可选，如果使用OpenAI模型）
OPENAI_API_KEY=your_openai_api_key_here

# 阿里云千问API密钥（推荐使用，默认模型）
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Google Gemini API密钥（可选，如果使用Gemini模型）
GOOGLE_API_KEY=your_google_api_key_here

# SearchAPI密钥（必需，用于Google搜索、航班、酒店等）
SEARCHAPI_API_KEY=your_searchapi_key_here

# Google Calendar OAuth2配置（可选，用于日历集成）
# 从Google Cloud Console获取，下载JSON凭据文件
# GOOGLE_CALENDAR_CREDENTIALS_PATH=path/to/credentials.json
