# 复制此文件为 .env 并填入真实的 API Key

# SearchAPI（用于搜索机票/酒店/景点等实时数据）
# 申请地址：https://www.searchapi.io/
SEARCHAPI_API_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_API_KEY2=

# Google Gemini
GEMINI_API_KEY=

# Google APIs（地图等）
GOOGLE_API_KEY=

# Google Calendar OAuth2（可选，用于同步日历）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# 可选：专用机票/酒店/地图 API
FLIGHTS_API_KEY=
HOTELS_API_KEY=
MAPS_API_KEY=
